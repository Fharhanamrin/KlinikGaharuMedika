<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="laporan_tabel"
              pageWidth="595"
              pageHeight="842"
              orientation="Portrait"
              columnWidth="515"
              leftMargin="40"
              rightMargin="40"
              topMargin="32"
              bottomMargin="28"
              whenNoDataType="AllSectionsNoDetail"
              language="java">

    <parameter name="KLINIK_NAMA" class="java.lang.String"/>
    <parameter name="KLINIK_INITIAL" class="java.lang.String"/>
    <parameter name="KLINIK_ALAMAT" class="java.lang.String"/>
    <parameter name="REPORT_TITLE" class="java.lang.String"/>
    <parameter name="PERIODE_LABEL" class="java.lang.String"/>
    <parameter name="DICETAK_LABEL" class="java.lang.String"/>
    <parameter name="TEMPAT_TANGGAL_LABEL" class="java.lang.String"/>
    <parameter name="COLUMN_1" class="java.lang.String"/>
    <parameter name="COLUMN_2" class="java.lang.String"/>
    <parameter name="COLUMN_3" class="java.lang.String"/>
    <parameter name="COLUMN_4" class="java.lang.String"/>
    <parameter name="COLUMN_5" class="java.lang.String"/>
    <parameter name="COLUMN_6" class="java.lang.String"/>
    <parameter name="COLUMN_7" class="java.lang.String"/>
    <parameter name="SUMMARY_LABEL" class="java.lang.String"/>
    <parameter name="SUMMARY_VALUE" class="java.lang.String"/>

    <field name="col1" class="java.lang.String"/>
    <field name="col2" class="java.lang.String"/>
    <field name="col3" class="java.lang.String"/>
    <field name="col4" class="java.lang.String"/>
    <field name="col5" class="java.lang.String"/>
    <field name="col6" class="java.lang.String"/>
    <field name="col7" class="java.lang.String"/>

    <title>
        <band height="116">
            <rectangle>
                <reportElement x="0" y="0" width="30" height="30" forecolor="#1C704D" backcolor="#1C704D" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>
            <textField>
                <reportElement x="0" y="5" width="30" height="20" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="14" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{KLINIK_INITIAL}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="40" y="0" width="320" height="18"/>
                <textElement verticalAlignment="Middle">
                    <font size="13" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{KLINIK_NAMA}.toUpperCase()]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="40" y="18" width="475" height="18"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{KLINIK_ALAMAT}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="44" width="515" height="1" forecolor="#333333"/>
                <graphicElement>
                    <pen lineWidth="1.2"/>
                </graphicElement>
            </line>
            <textField>
                <reportElement x="0" y="58" width="515" height="28"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="16" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{REPORT_TITLE}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="88" width="255" height="15"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{PERIODE_LABEL}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="260" y="88" width="255" height="15"/>
                <textElement textAlignment="Right">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{DICETAK_LABEL}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="24">
            <rectangle>
                <reportElement x="0" y="0" width="515" height="24" forecolor="#E5E0D6" backcolor="#F2F0EA" mode="Opaque"/>
            </rectangle>
            <staticText>
                <reportElement x="0" y="0" width="24" height="24"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[No]]></text>
            </staticText>
            <textField>
                <reportElement x="24" y="0" width="64" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{COLUMN_1}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="88" y="0" width="112" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{COLUMN_2}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="200" y="0" width="72" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{COLUMN_3}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="272" y="0" width="61" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{COLUMN_4}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="333" y="0" width="64" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{COLUMN_5}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="397" y="0" width="54" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{COLUMN_6}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="451" y="0" width="64" height="24"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{COLUMN_7}]]></textFieldExpression>
            </textField>
        </band>
    </columnHeader>

    <detail>
        <band height="22">
            <textField>
                <reportElement x="0" y="0" width="24" height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[String.valueOf($V{REPORT_COUNT})]]></textFieldExpression>
            </textField>
            <textField textAdjust="ScaleFont">
                <reportElement x="24" y="0" width="64" height="22"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{col1}]]></textFieldExpression>
            </textField>
            <textField textAdjust="ScaleFont">
                <reportElement x="88" y="0" width="112" height="22"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{col2}]]></textFieldExpression>
            </textField>
            <textField textAdjust="ScaleFont">
                <reportElement x="200" y="0" width="72" height="22"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{col3}]]></textFieldExpression>
            </textField>
            <textField textAdjust="ScaleFont">
                <reportElement x="272" y="0" width="61" height="22"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{col4}]]></textFieldExpression>
            </textField>
            <textField textAdjust="ScaleFont">
                <reportElement x="333" y="0" width="64" height="22"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{col5}]]></textFieldExpression>
            </textField>
            <textField textAdjust="ScaleFont">
                <reportElement x="397" y="0" width="54" height="22"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{col6}]]></textFieldExpression>
            </textField>
            <textField textAdjust="ScaleFont">
                <reportElement x="451" y="0" width="64" height="22"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{col7}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="21" width="515" height="1" forecolor="#E7E2D9"/>
            </line>
        </band>
    </detail>

    <pageFooter>
        <band height="108">
            <textField>
                <reportElement x="292" y="0" width="223" height="16"/>
                <textElement textAlignment="Center">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{TEMPAT_TANGGAL_LABEL}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="292" y="24" width="98" height="16"/>
                <textElement textAlignment="Center">
                    <font size="9"/>
                </textElement>
                <text><![CDATA[Kepala Klinik]]></text>
            </staticText>
            <staticText>
                <reportElement x="417" y="24" width="98" height="16"/>
                <textElement textAlignment="Center">
                    <font size="9"/>
                </textElement>
                <text><![CDATA[Admin]]></text>
            </staticText>
            <staticText>
                <reportElement x="292" y="78" width="98" height="16"/>
                <textElement textAlignment="Center">
                    <font size="9"/>
                </textElement>
                <text><![CDATA[(............................)]]></text>
            </staticText>
            <staticText>
                <reportElement x="417" y="78" width="98" height="16"/>
                <textElement textAlignment="Center">
                    <font size="9"/>
                </textElement>
                <text><![CDATA[(............................)]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="88" width="90" height="14"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["Halaman " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <summary>
        <band height="54">
            <line>
                <reportElement x="0" y="8" width="515" height="1" forecolor="#333333"/>
            </line>
            <textField>
                <reportElement x="302" y="20" width="100" height="16"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{SUMMARY_LABEL}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="402" y="20" width="113" height="16"/>
                <textElement textAlignment="Right">
                    <font size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{SUMMARY_VALUE}]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>
